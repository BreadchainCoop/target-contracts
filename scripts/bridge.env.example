# Bridge Script Environment Variables
# Copy this file to bridge.env and fill in the values

# Required: Private key for deployment and transactions
PRIVATE_KEY=

# Required: L1 RPC URL (e.g., Sepolia, Holesky, Mainnet)
L1_RPC_URL=

# Required: L2 RPC URL (e.g., Gnosis, Arbitrum, etc.)
L2_RPC_URL=

# Required: Registry coordinator address on L1 to bridge from
REGISTRY_COORDINATOR_ADDRESS=

# Optional: Slot number for mock proof (default: 12345)
# SLOT_NUMBER=12345

# Optional: Skip deployment and use existing contracts
# SKIP_DEPLOY=true
# L1_DEPLOY_FILE=/path/to/l1-deploy.json
# L2_DEPLOY_FILE=/path/to/l2-deploy.json
