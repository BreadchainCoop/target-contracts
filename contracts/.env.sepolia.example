# Sepolia Deployment Configuration
PRIVATE_KEY=
RPC_URL=https://1rpc.io/sepolia
ETHERSCAN_API_KEY=

# AVS Registry Coordinator on Sepolia (REQUIRED)
# You need to deploy or reference an existing Registry Coordinator
REGISTRY_COORDINATOR_ADDRESS=

# Optional: SP1 Helios address (leave empty to use address(0))
SP1HELIOS_ADDRESS=

# Optional: Custom output path for deployment artifacts
OUT_PATH=./artifacts/sepolia-deploy.json

