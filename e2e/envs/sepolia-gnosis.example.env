# ==================================== #
#  Sepolia L1 + Gnosis Chain L2 Config #
# ==================================== #

# Environment
ENVIRONMENT=TESTNET

# ============ L1 (Sepolia) ============ #

# EigenLayer Core Contracts on Sepolia (v1.9.0-rc.0)
DELEGATION_MANAGER_ADDRESS=0xD4A7E1Bd8015057293f0D0A557088c286942e84b
STRATEGY_MANAGER_ADDRESS=0x2E3D6c0744b10eb0A4e6F679F71554a39Ec47a5D
EIGENPOD_MANAGER_ADDRESS=0x56BfEb94879F4543E756d26103976c567256034a
AVS_DIRECTORY_ADDRESS=0xa789c91ECDdae96865913130B786140Ee17aF545
REWARDS_COORDINATOR_ADDRESS=0x5ae8152fb88c26ff9ca5C014c94fca3c68029349
ALLOCATION_MANAGER_ADDRESS=0x42583067658071247ec8CE0A516A58f682002d07
PERMISSION_CONTROLLER_ADDRESS=0x44632dfBdCb6D3E21EF613B0ca8A6A0c618F5a37

# Strategy Contracts on Sepolia
STRATEGY_FACTORY_ADDRESS=0x066cF95c1bf0927124DFB8B02B401bc23A79730D
STRATEGY_BASE_ADDRESS=0x427e627Bc7E83cac0f84337d3Ad94230C32697D3
EIGEN_STRATEGY_ADDRESS=0x8E93249a6C37a32024756aaBd813E6139b17D1d5

# LST (Liquid Staking Token) - stETH on Sepolia
LST_CONTRACT_ADDRESS=0x00c71b0fCadE911B2feeE9912DE4Fe19eB04ca56
LST_STRATEGY_ADDRESS=0x8b29d91e67b013e855EaFe0ad704aC4Ab086a574

# AVS Registry Coordinator (DEPLOYED BY gas-killer-router)
# Set this after running: make deploy-avs NETWORK=sepolia
REGISTRY_COORDINATOR_ADDRESS=

# Middleware Contracts (DEPLOYED BY this repo)
# Set after running DeploySepolia.s.sol
BLS_SIGNATURE_CHECKER_ADDRESS=
OPERATOR_STATE_RETRIEVER_ADDRESS=
MIDDLEWARE_SHIM_ADDRESS=

# L1 RPC
L1_RPC_URL=https://1rpc.io/sepolia
RPC_URL=https://1rpc.io/sepolia

# L1 Fork URL (for local testing)
L1_FORK_URL=

# ============ L2 (Gnosis Chain) ============ #

# Gnosis Chain Configuration
L2_CHAIN_ID=100
L2_RPC_URL=https://rpc.gnosischain.com

# Alternative Gnosis RPCs
# L2_RPC_URL=https://gnosis.drpc.org
# L2_RPC_URL=https://gnosis-mainnet.public.blastapi.io

# L2 Contracts (DEPLOYED BY this repo)
# Set after running DeployL2.s.sol
REGISTRY_COORDINATOR_MIMIC_ADDRESS=
L2_BLS_SIGNATURE_CHECKER_ADDRESS=
SIGNATURE_CONSUMER_ADDRESS=

# L2 Fork URL (for local testing)
L2_FORK_URL=

# ============ SP1 Helios ============ #

# SP1 Helios Address (deploy or use existing)
# For initial testing, use mock mode
SP1HELIOS_ADDRESS=
IS_SP1HELIOS_MOCK=1

# Beacon Chain RPC for proof generation (required for real proofs)
# Sepolia beacon chain endpoints:
# - https://lodestar-sepolia.chainstacklabs.com
# - https://ethereum-sepolia-beacon-api.publicnode.com
BEACON_CHAIN_RPC=

# ============ Deployment Keys ============ #

# Deployer private key (with ETH on both Sepolia and Gnosis)
PRIVATE_KEY=
DEPLOYER_KEY=

# Funded key for operator registration/staking
FUNDED_KEY=

# ============ Verification ============ #

# Etherscan API Keys
L1_ETHERSCAN_API_KEY=
L2_ETHERSCAN_API_KEY=
ETHERSCAN_API_KEY=

# ============ Signer Service ============ #

# Cerberus Configuration
CERBERUS_GRPC_PORT=50051
CERBERUS_METRICS_PORT=9081
SIGNER_ENDPOINT=http://signer:50051

# ============ Operators ============ #

# Number of operators
NODE_COUNT=3
MAX_OPERATOR_RETRY_ATTEMPTS=10

# Quorum configuration
MINIMUM_STAKE=1
MAX_OPERATOR_COUNT=32

# ============ Output Paths ============ #

# Deployment artifacts
L1_OUT_PATH=./artifacts/l1-deploy.json
L2_OUT_PATH=./artifacts/l2-deploy.json
PROOF_FILE=./artifacts/middlewareDataProof.json

# ============ NOTES ============ #
# 1. All EigenPod functionality is PAUSED on Sepolia
# 2. Registry Coordinator must be deployed via gas-killer-router first
# 3. SP1Helios should be mocked initially, deploy for production
# 4. Gnosis Chain uses xDAI for gas - ensure deployer has funds
